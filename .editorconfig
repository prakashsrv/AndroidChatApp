root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120

[*.kts]
indent_size = 4

# ktlint — disable rules that conflict with Compose conventions or are too noisy
[{*.kt,*.kts}]
ktlint_standard_filename = disabled                  # Composables don't have to match file name
ktlint_standard_function-naming = disabled           # Composables use PascalCase
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled
